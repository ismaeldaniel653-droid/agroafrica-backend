# ═══════════════════════════════════════
# AgroAfrica Backend — Variables d'environnement
# ═══════════════════════════════════════

# MongoDB
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/agroafrica

# JWT
JWT_SECRET=votre_secret_ultra_securise_ici

# Serveur
PORT=5000
NODE_ENV=development

# Frontend (CORS)
CLIENT_URL=http://localhost:5173

# ═══════════════════════════════════════
# EMAIL (NodeMailer) — Optionnel
# ═══════════════════════════════════════
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre-email@gmail.com
SMTP_PASS=votre-mot-de-passe-app

# ═══════════════════════════════════════
# PAIEMENTS — APIs en production
# ═══════════════════════════════════════
# MTN MoMo
MTN_API_KEY=
MTN_API_USER=
MTN_SUBSCRIPTION_KEY=
MTN_ENVIRONMENT=sandbox

# Orange Money
ORANGE_MONEY_API_KEY=
ORANGE_MONEY_API_SECRET=

# Wave
WAVE_API_KEY=

# ═══════════════════════════════════════
# REDIS (Cache) — Optionnel
# ═══════════════════════════════════════
REDIS_URL=redis://localhost:6379

# ═══════════════════════════════════════
# CLOUDINARY (Upload photos) — Optionnel
# ═══════════════════════════════════════
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=